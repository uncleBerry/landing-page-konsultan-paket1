---
const WA_URL = 'https://wa.me/6280000000000?text=Halo%2C%20saya%20butuh%20bantuan%20urus%20SBU%20untuk%20PT%20saya%21';

const guarantees = [
  '✅ Garansi 100% Uang Kembali',
  '⚡ Proses Tercepat',
  '🔒 100% Legal & Resmi',
  '📞 Respon 5 Menit',
];
---

<section class="bg-navy-900 relative overflow-hidden py-16 md:py-28">

  <!-- Decorative shapes -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-0 w-72 h-72 rounded-full bg-navy-700 opacity-30 translate-x-1/2 -translate-y-1/2 blur-2xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 rounded-full bg-navy-950 opacity-60 -translate-x-1/2 translate-y-1/2 blur-3xl"></div>
    <!-- Clock icon watermark -->
    <svg class="absolute top-8 left-8 w-32 h-32 text-white opacity-[0.04]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 text-center">

    <!-- Urgency badge -->
    <div
      class="inline-flex items-center gap-2 bg-red-500 text-white text-sm font-bold px-5 py-2 rounded-full mb-8 shadow-lg"
      data-aos="fade-down"
    >
      <span class="w-2.5 h-2.5 rounded-full bg-white animate-pulse shrink-0" aria-hidden="true"></span>
      ⚠️ PERHATIAN: Slot Prioritas Minggu Ini Terbatas!
    </div>

    <!-- H2 -->
    <h2
      class="text-white text-3xl md:text-5xl font-extrabold mb-6 leading-tight"
      data-aos="fade-up"
    >
      Waktu Tender Terus Berjalan.{' '}
      <span class="text-orange-400">Amankan SBU Anda Hari Ini!</span>
    </h2>

    <!-- Sub-headline -->
    <p
      class="text-blue-200 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed"
      data-aos="fade-up"
      data-aos-delay="80"
    >
      Dapatkan jaminan 100% uang kembali dan proses kilat. Slot prioritas minggu ini tersisa sedikit.
    </p>

    <!-- Guarantee pills -->
    <div
      class="flex flex-wrap justify-center gap-3 mb-10"
      data-aos="fade-up"
      data-aos-delay="140"
    >
      {guarantees.map(g => (
        <span class="bg-white/10 backdrop-blur-sm text-white text-sm font-semibold px-4 py-2 rounded-full border border-white/10">
          {g}
        </span>
      ))}
    </div>

    <!-- Main CTA with pulse animation -->
    <div data-aos="zoom-in" data-aos-delay="200">
      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-orange-500 hover:bg-orange-600 text-white font-extrabold text-xl px-10 py-5 rounded-full transition-all duration-300 hover:scale-105 animate-pulse-cta shadow-2xl shadow-orange-500/30 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-400"
        aria-label="Klaim konsultasi gratis via WhatsApp"
      >
        <svg class="w-7 h-7 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Klaim Gratis Konsultasi Dokumen Sekarang
      </a>
      <p class="text-blue-300 text-sm mt-4">
        Klik tombol di atas → Chat otomatis terbuka → Konsultan langsung merespon
      </p>
    </div>

    <!-- Scarcity counter -->
    <div
      class="mt-12 inline-flex items-center gap-5 bg-white/5 border border-white/10 rounded-2xl px-8 py-5"
      data-aos="fade-up"
      data-aos-delay="280"
    >
      <div class="text-center">
        <p class="text-orange-400 text-4xl font-black leading-none">3</p>
        <p class="text-blue-300 text-xs uppercase tracking-widest mt-1">Slot Tersisa</p>
      </div>
      <div class="w-px h-12 bg-white/20" aria-hidden="true"></div>
      <div class="text-left">
        <p class="text-white font-semibold">Minggu ini · Prioritas Ekspres</p>
        <p class="text-blue-300 text-xs mt-0.5">Diperbarui setiap hari Senin</p>
      </div>
    </div>

  </div>
</section>
