---
const logos = [
  { abbr: 'WK', name: 'PT Waskita Karya'        },
  { abbr: 'PP', name: 'PT Pembangunan Perumahan' },
  { abbr: 'AK', name: 'PT Adhi Karya'            },
  { abbr: 'WJ', name: 'PT Wijaya Karya'          },
  { abbr: 'BA', name: 'PT Brantas Abipraya'      },
];

const trustBadges = [
  { icon: '🏛️', label: 'Terdaftar LPJK PUPR'  },
  { icon: '🔒', label: 'Data Perusahaan Aman'  },
  { icon: '📜', label: 'Proses Transparan'      },
  { icon: '⭐', label: 'Rating 4.9/5 · 200+ ulasan' },
];
---

<section class="bg-[#f5f7fb] py-12 md:py-16 border-b border-gray-100">
  <div class="max-w-6xl mx-auto px-4">

    <p
      class="text-center text-gray-400 text-sm uppercase tracking-widest font-medium mb-8"
      data-aos="fade-up"
    >
      Dipercaya oleh 500+ Kontraktor &amp; Perusahaan Konstruksi
    </p>

    <!-- Logo strip: horizontal scroll on mobile, centered on desktop -->
    <div
      class="flex items-center gap-8 overflow-x-auto pb-2 snap-x md:overflow-visible md:justify-center md:flex-wrap"
      data-aos="fade-up"
      data-aos-delay="100"
      role="list"
      aria-label="Klien kami"
    >
      {logos.map(logo => (
        <div
          class="flex-none flex flex-col items-center gap-2 grayscale opacity-50 hover:opacity-80 hover:grayscale-0 transition-all duration-300 snap-start"
          role="listitem"
        >
          <div class="w-24 h-14 bg-white rounded-xl border border-gray-200 flex items-center justify-center shadow-sm">
            <span class="text-gray-700 text-sm font-extrabold tracking-wide">{logo.abbr}</span>
          </div>
          <span class="text-gray-500 text-xs font-medium whitespace-nowrap">{logo.name}</span>
        </div>
      ))}
    </div>

    <!-- Trust badges -->
    <div
      class="mt-10 flex flex-wrap justify-center gap-4 md:gap-6"
      data-aos="fade-up"
      data-aos-delay="180"
    >
      {trustBadges.map(badge => (
        <div class="flex items-center gap-2 text-sm text-gray-500 font-medium">
          <span aria-hidden="true">{badge.icon}</span>
          <span>{badge.label}</span>
        </div>
      ))}
    </div>

  </div>
</section>
