---
const WA_URL = 'https://wa.me/6280000000000?text=Halo%2C%20saya%20butuh%20bantuan%20urus%20SBU%20untuk%20PT%20saya%21';

const benefits = [
  {
    badge: 'Garansi Penuh',
    badgeClass: 'bg-emerald-100 text-emerald-700',
    iconBg: 'bg-emerald-50 text-emerald-600',
    borderClass: 'border-emerald-200',
    title: 'Jaminan 100% Uang Kembali',
    desc: 'Garansi uang kembali penuh jika dokumen ditolak sistem pemerintah. Tanpa syarat, tanpa pertanyaan.',
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    badge: 'Tercepat',
    badgeClass: 'bg-orange-100 text-orange-700',
    iconBg: 'bg-orange-50 text-orange-500',
    borderClass: 'border-orange-200',
    title: 'Proses Tercepat di Kelasnya',
    desc: 'Berkas langsung diproses hari itu juga. Jalur prioritas eksklusif kami memastikan SBU Anda terbit dalam waktu tercepat.',
    iconPath: 'M13 10V3L4 14h7v7l9-11h-7z',
  },
  {
    badge: 'Gratis',
    badgeClass: 'bg-blue-100 text-blue-700',
    iconBg: 'bg-blue-50 text-blue-600',
    borderClass: 'border-blue-200',
    title: 'Gratis Konsultasi Pra-Syarat',
    desc: 'Tim ahli kami siap mendampingi pengecekan dokumen sebelum proses dimulai. Tidak ada biaya tersembunyi.',
    iconPath: 'M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z',
  },
];
---

<section id="solution" class="bg-[#f5f7fb] py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4">

    <!-- Section header -->
    <div class="text-center mb-14" data-aos="fade-up">
      <span class="inline-block bg-blue-50 text-blue-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-4">
        Mengapa Memilih Kami
      </span>
      <h2 class="text-navy-900 text-3xl md:text-4xl font-extrabold mb-4">
        Solusi Cepat, Aman &amp; Bergaransi
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Kami bukan sekadar jasa pengurusan biasa. Kami adalah mitra legal terpercaya yang telah membantu ratusan kontraktor.
      </p>
    </div>

    <!-- 3 Benefit Cards: stacked mobile / side-by-side desktop -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-14">
      {benefits.map((item, i) => (
        <div
          class={`bg-white rounded-2xl p-7 border-2 ${item.borderClass} hover:shadow-xl transition-all duration-300 hover:-translate-y-1 relative overflow-hidden`}
          data-aos="fade-up"
          data-aos-delay={i * 120}
        >
          <span class={`inline-block text-xs font-bold px-2.5 py-1 rounded-full mb-5 ${item.badgeClass}`}>
            {item.badge}
          </span>
          <div class={`w-16 h-16 rounded-2xl ${item.iconBg} flex items-center justify-center mb-5`}>
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.iconPath}/>
            </svg>
          </div>
          <h3 class="text-navy-900 font-bold text-xl mb-3">{item.title}</h3>
          <p class="text-gray-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center" data-aos="fade-up">
      <a
        href={WA_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-lg px-8 py-4 rounded-full transition-all duration-300 hover:scale-105 shadow-lg shadow-emerald-500/25"
      >
        Dapatkan Konsultasi Gratis Sekarang →
      </a>
      <p class="text-gray-400 text-sm mt-3">Tidak perlu datang ke kantor. Cukup via WhatsApp.</p>
    </div>

  </div>
</section>
