  {
    name: 'Budi Santoso',
    company: 'PT Maju Jaya Konstruksi',
    city: 'Jakarta',
    avatar: 'BS',
    avatarBg: 'bg-orange-400',
    time: '10:42',
    result: 'SBU terbit dalam 2 hari kerja',
    messages: [
      { from: 'them', text: 'Halo, saya butuh SBU untuk PT saya sebelum tender minggu depan 😭' },
